# ========================================
# Event Ticketing Platform - Environment Variables
# ========================================

# ========================================
# PostgreSQL Configuration
# ========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=eventticket_db

# Individual Database Names
user_db=user_db
ORGANIZATION_DB=organization_db
EVENT_DB=event_db
ORDER_DB=order_db
TICKET_DB=ticket_db
PAYMENT_DB=payment_db
NOTIFICATION_DB=notification_db
ANALYTICS_DB=analytics_db

# ========================================
# Redis Configuration
# ========================================
REDIS_PASSWORD=REDIS_PASSWORD-0
REDIS_HOST=redis
REDIS_PORT=6379

# ========================================
# Kafka Configuration
# ========================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# ========================================
# Keycloak Configuration
# ========================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=keycloakadm
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloakdbadm
KEYCLOAK_DB_NAME=keycloak_db

# Keycloak Client Configuration
KEYCLOAK_REALM=event-ticketing
KEYCLOAK_CLIENT_ID=event-ticketing-client
KEYCLOAK_CLIENT_SECRET=your_client_secret_here
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8180

# ========================================
# Email Configuration (Brevo SMTP)
# ========================================
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=your_brevo_username_here
BREVO_SMTP_PASSWORD=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@eventticket.com
BREVO_SENDER_NAME=Event Ticketing Platform

# ========================================
# Firebase Cloud Messaging (FCM)
# ========================================
FCM_PROJECT_ID=your_firebase_project_id
FCM_PRIVATE_KEY_ID=your_private_key_id
FCM_PRIVATE_KEY=your_private_key_here
FCM_CLIENT_EMAIL=your_service_account_email
FCM_CLIENT_ID=your_client_id
FCM_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FCM_TOKEN_URI=https://oauth2.googleapis.com/token
FCM_CREDENTIALS_FILE=/app/config/firebase-credentials.json

# ========================================
# Service Ports
# ========================================
DISCOVERY_SERVICE_PORT=8761
CONFIG_SERVER_PORT=8888
API_GATEWAY_PORT=8080

IDENTITY_SERVICE_PORT=8081
ORGANIZATION_SERVICE_PORT=8082
EVENT_SERVICE_PORT=8083
ORDER_SERVICE_PORT=8084
TICKET_SERVICE_PORT=8085
PAYMENT_SERVICE_PORT=8086
NOTIFICATION_SERVICE_PORT=8087
ANALYTICS_SERVICE_PORT=8088

# ========================================
# Application Configuration
# ========================================
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=your_jwt_secret_key_min_256_bits_here
JWT_EXPIRATION=86400000

# ========================================
# Payment Gateway (Mock)
# ========================================
PAYMENT_GATEWAY_MODE=mock
PAYMENT_GATEWAY_API_KEY=mock_api_key
PAYMENT_SUCCESS_RATE=0.9

# ========================================
# File Upload Configuration
# ========================================
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=20MB
UPLOAD_DIR=/app/uploads

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL=INFO
LOG_PATTERN=%d{yyyy-MM-dd HH:mm:ss} - %msg%n

# ========================================
# CORS Configuration
# ========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_MAX_AGE=3600

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ========================================
# Monitoring & Actuator
# ========================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
