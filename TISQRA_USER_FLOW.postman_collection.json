{
  "info": {
    "name": "TISQRA Platform - User Flow (Gateway)",
    "description": "User-flow ordered collection for TISQRA (Gateway base URL). Includes seeded credentials and role folders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8080" },
    { "key": "ACCESS_TOKEN", "value": "" },
    { "key": "USER_ID", "value": "" },
    { "key": "ORG_ID", "value": "" },
    { "key": "EVENT_ID", "value": "" },
    { "key": "ORDER_ID", "value": "" },
    { "key": "TICKET_ID", "value": "" },
    { "key": "PAYMENT_ID", "value": "" },
    { "key": "SCANNER_ID", "value": "" },
    { "key": "START_DATE", "value": "2026-01-01" },
    { "key": "END_DATE", "value": "2026-12-31" }
  ],
  "item": [
    {
      "name": "0) Auth",
      "item": [
        {
          "name": "Register (Guest)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newguest@example.com\",\n  \"email\": \"newguest@example.com\",\n  \"password\": \"Guest12345!\",\n  \"firstName\": \"New\",\n  \"lastName\": \"Guest\",\n  \"phone\": \"+21600000000\",\n  \"role\": \"GUEST\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login (SuperAdmin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@eventticketing.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login (AdminOrg)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizer@eventticketing.com\",\n  \"password\": \"organizer123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login (Scanner)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"scanner@eventticketing.com\",\n  \"password\": \"scanner123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login (Guest)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"guest@eventticketing.com\",\n  \"password\": \"guest123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/auth/logout?userId={{USER_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "logout"],
              "query": [{ "key": "userId", "value": "{{USER_ID}}" }]
            }
          }
        },
        {
          "name": "Verify email",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{BASE_URL}}/api/auth/email/verify?token={{VERIFY_TOKEN}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "email", "verify"],
              "query": [{ "key": "token", "value": "{{VERIFY_TOKEN}}" }]
            }
          }
        },
        {
          "name": "Password reset request",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{BASE_URL}}/api/auth/password/reset-request?email={{EMAIL}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "password", "reset-request"],
              "query": [{ "key": "email", "value": "{{EMAIL}}" }]
            }
          }
        },
        {
          "name": "Password reset",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{RESET_TOKEN}}\",\n  \"newPassword\": \"NewPass123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/password/reset",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "password", "reset"]
            }
          }
        }
      ]
    },
    {
      "name": "1) Users (SuperAdmin/AdminOrg)",
      "item": [
        {
          "name": "Get all users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/users?page=0&size=20",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "users"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get user by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/users/{{USER_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "users", "{{USER_ID}}"]
            }
          }
        },
        {
          "name": "Get user by email",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/users/email/admin@eventticketing.com",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "users", "email", "admin@eventticketing.com"]
            }
          }
        },
        {
          "name": "Get user by keycloak id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/users/keycloak/{{KEYCLOAK_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "users", "keycloak", "{{KEYCLOAK_ID}}"]
            }
          }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Updated\",\n  \"phone\": \"+21600000000\",\n  \"profileImageUrl\": null\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/users/{{USER_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "users", "{{USER_ID}}"]
            }
          }
        },
        {
          "name": "Deactivate user (SuperAdmin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/users/{{USER_ID}}/deactivate",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "users", "{{USER_ID}}", "deactivate"]
            }
          }
        },
        {
          "name": "Activate user (SuperAdmin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/users/{{USER_ID}}/activate",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "users", "{{USER_ID}}", "activate"]
            }
          }
        }
      ]
    },
    {
      "name": "2) Organizations (AdminOrg)",
      "item": [
        {
          "name": "Create organization",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tech Corp\",\n  \"email\": \"org@techcorp.com\",\n  \"phone\": \"+21600000000\",\n  \"address\": \"123 Main St\",\n  \"city\": \"Tunis\",\n  \"country\": \"TN\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/organizations",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "organizations"]
            }
          }
        },
        {
          "name": "List organizations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/organizations?page=0&size=20",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "organizations"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get organization",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/organizations/{{ORG_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "organizations", "{{ORG_ID}}"]
            }
          }
        },
        {
          "name": "Update organization",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tech Corp Updated\",\n  \"email\": \"org@techcorp.com\",\n  \"phone\": \"+21600000000\",\n  \"address\": \"456 Second St\",\n  \"city\": \"Tunis\",\n  \"country\": \"TN\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/organizations/{{ORG_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "organizations", "{{ORG_ID}}"]
            }
          }
        }
      ]
    },
    {
      "name": "3) Events (browse + manage)",
      "item": [
        {
          "name": "List upcoming events (public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/events/upcoming?page=0&size=20",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "events", "upcoming"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Search events (public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/events/search?query=tech&page=0&size=20",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "events", "search"],
              "query": [
                { "key": "query", "value": "tech" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get event by id (public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/events/{{EVENT_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "events", "{{EVENT_ID}}"]
            }
          }
        },
        {
          "name": "Create event (AdminOrg/SuperAdmin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationId\": \"{{ORG_ID}}\",\n  \"name\": \"Tech Conference 2026\",\n  \"slug\": \"tech-conference-2026\",\n  \"description\": \"A major technology conference\",\n  \"category\": \"TECHNOLOGY\",\n  \"startDate\": \"2026-06-01T09:00:00\",\n  \"endDate\": \"2026-06-03T18:00:00\",\n  \"capacity\": 5000\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/events",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "events"]
            }
          }
        },
        {
          "name": "Update event (AdminOrg/SuperAdmin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationId\": \"{{ORG_ID}}\",\n  \"name\": \"Tech Conference 2026 Updated\",\n  \"slug\": \"tech-conference-2026\",\n  \"description\": \"Updated description\",\n  \"category\": \"TECHNOLOGY\",\n  \"startDate\": \"2026-06-01T09:00:00\",\n  \"endDate\": \"2026-06-03T18:00:00\",\n  \"capacity\": 6000\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/events/{{EVENT_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "events", "{{EVENT_ID}}"]
            }
          }
        },
        {
          "name": "Publish event (AdminOrg/SuperAdmin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/events/{{EVENT_ID}}/publish",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "events", "{{EVENT_ID}}", "publish"]
            }
          }
        },
        {
          "name": "Cancel event (AdminOrg/SuperAdmin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/events/{{EVENT_ID}}/cancel",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "events", "{{EVENT_ID}}", "cancel"]
            }
          }
        }
      ]
    },
    {
      "name": "4) Orders & Payments (Guest)",
      "item": [
        {
          "name": "Create order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{USER_ID}}\",\n  \"eventId\": \"{{EVENT_ID}}\",\n  \"quantity\": 2,\n  \"totalPrice\": 100.0\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/orders",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Get order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/orders/{{ORDER_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "orders", "{{ORDER_ID}}"]
            }
          }
        },
        {
          "name": "Process payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{ORDER_ID}}\",\n  \"amount\": 100.0,\n  \"currency\": \"USD\",\n  \"paymentMethod\": \"CARD\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/payments/process",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "payments", "process"]
            }
          }
        },
        {
          "name": "Refund payment (AdminOrg/SuperAdmin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Customer requested\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/payments/{{PAYMENT_ID}}/refund",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "payments", "{{PAYMENT_ID}}", "refund"]
            }
          }
        }
      ]
    },
    {
      "name": "5) Tickets (QR generate/validate)",
      "item": [
        {
          "name": "Generate tickets for order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"orderId\": \"{{ORDER_ID}}\"\n}" },
            "url": {
              "raw": "{{BASE_URL}}/api/tickets/generate",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "tickets", "generate"]
            }
          }
        },
        {
          "name": "Validate ticket (Scanner/AdminOrg)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/tickets/validate?qrCode={{QR_CODE}}&scannerId={{SCANNER_ID}}&scannerName=MainGate",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "tickets", "validate"],
              "query": [
                { "key": "qrCode", "value": "{{QR_CODE}}" },
                { "key": "scannerId", "value": "{{SCANNER_ID}}" },
                { "key": "scannerName", "value": "MainGate" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "6) Analytics (AdminOrg/SuperAdmin)",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/analytics/dashboard/{{ORG_ID}}?startDate={{START_DATE}}&endDate={{END_DATE}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "analytics", "dashboard", "{{ORG_ID}}"],
              "query": [
                { "key": "startDate", "value": "{{START_DATE}}" },
                { "key": "endDate", "value": "{{END_DATE}}" }
              ]
            }
          }
        },
        {
          "name": "Event sales report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN}}" }],
            "url": {
              "raw": "{{BASE_URL}}/api/analytics/event/{{EVENT_ID}}/sales?startDate={{START_DATE}}&endDate={{END_DATE}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "analytics", "event", "{{EVENT_ID}}", "sales"],
              "query": [
                { "key": "startDate", "value": "{{START_DATE}}" },
                { "key": "endDate", "value": "{{END_DATE}}" }
              ]
            }
          }
        }
      ]
    }
  ]
}

