{
  "info": {
    "name": "TISQRA Platform - API Collection",
    "description": "Clean Postman collection aligned with current controller endpoints and DTO request fields. Use {{BASE_URL}} as API Gateway base.\n\nRecommended auth order: Register → Verify email (paste 6-digit code or full link into {{VERIFY_TOKEN}}) → Login → Logout.\n\nDocker dev: MailHog UI at http://localhost:8025 — open the verification message, copy the 6-digit verification code into {{VERIFY_TOKEN}}. Resend uses {{EMAIL}} (set by Register test script).\n\nProduction: set EMAIL_HOST/PORT/USER/PASS (and EMAIL_SMTP_AUTH=true, EMAIL_SMTP_STARTTLS=true for TLS providers).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8080" },
    { "key": "ACCESS_TOKEN", "value": "" },
    { "key": "USER_ID", "value": "" },
    { "key": "ORG_ID", "value": "" },
    { "key": "EVENT_ID", "value": "" },
    { "key": "ORDER_ID", "value": "" },
    { "key": "ORDER_NUMBER", "value": "" },
    { "key": "PAYMENT_ID", "value": "" },
    { "key": "PAYMENT_PROVIDER_PAYMENT_ID", "value": "" },
    { "key": "TICKET_ID", "value": "" },
    { "key": "NOTIFICATION_ID", "value": "" },
    { "key": "SCANNER_ID", "value": "" },
    { "key": "QR_CODE", "value": "" },
    { "key": "TICKET_CATEGORY_ID", "value": "" },
    { "key": "PROMO_CODE", "value": "SAVE10" },
    { "key": "PROMO_CODE_ID", "value": "" },
    { "key": "PAGE", "value": "0" },
    { "key": "SIZE", "value": "20" },
    { "key": "START_DATE", "value": "2026-01-01" },
    { "key": "END_DATE", "value": "2026-12-31" },
    { "key": "VERIFY_TOKEN", "value": "" },
    { "key": "RESET_TOKEN", "value": "" },
    { "key": "EMAIL", "value": "guest@eventticketing.com" },
    { "key": "NEW_PASSWORD", "value": "NewPass123!" },
    { "key": "MANAGED_USER_EMAIL", "value": "managed.user@example.com" },
    { "key": "MANAGED_USER_PASSWORD", "value": "Managed123!" }
  ],
  "item": [
    {
      "name": "0) Auth",
      "item": [
        {
          "name": "Register (public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const body = JSON.parse(pm.request.body.raw || '{}');",
                  "  if (body.email) pm.collectionVariables.set('EMAIL', body.email);",
                  "} catch (e) {}",
                  "pm.test('Register returns 201', function () { pm.response.to.have.status(201); });",
                  "const j = pm.response.json();",
                  "pm.test('Register success', function () { pm.expect(j.success).to.be.true; });",
                  "if (j.success && j.data) {",
                  "  if (j.data.user && j.data.user.id) pm.collectionVariables.set('USER_ID', j.data.user.id);",
                  "  if (j.data.id) pm.collectionVariables.set('USER_ID', j.data.id);",
                  "  if (j.data.email) pm.collectionVariables.set('EMAIL', j.data.email);",
                  "}",
                  "// Register does not issue auth tokens; verify email then call Login.",
                  "// VERIFY_TOKEN is sent by email only — paste the 6-digit code (or full verify link) into collection variable VERIFY_TOKEN."
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newguest@example.com\",\n  \"email\": \"newguest@example.com\",\n  \"password\": \"Guest12345!\",\n  \"firstName\": \"New\",\n  \"lastName\": \"Guest\",\n  \"phone\": null,\n  \"userRole\": \"guest\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Verify email (6-digit code/token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Verify email returns 200', function () { pm.response.to.have.status(200); });",
                  "const j = pm.response.json();",
                  "pm.test('Verify email success', function () { pm.expect(j.success).to.be.true; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{BASE_URL}}/api/auth/email/verify?token={{VERIFY_TOKEN}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "email", "verify"],
              "query": [{ "key": "token", "value": "{{VERIFY_TOKEN}}" }]
            }
          }
        },
        {
          "name": "Resend verification email",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Resend returns 200', function () { pm.response.to.have.status(200); });",
                  "const j = pm.response.json();",
                  "pm.test('Resend success', function () { pm.expect(j.success).to.be.true; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{BASE_URL}}/api/auth/email/resend-verification?email={{EMAIL}}",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "email", "resend-verification"],
              "query": [{ "key": "email", "value": "{{EMAIL}}" }]
            }
          }
        },
        {
          "name": "Login (any role)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns 200', function () { pm.response.to.have.status(200); });",
                  "const j = pm.response.json();",
                  "if (j.success && j.data) {",
                  "  if (j.data.access_token) pm.collectionVariables.set('ACCESS_TOKEN', j.data.access_token);",
                  "  if (j.data.user && j.data.user.id) pm.collectionVariables.set('USER_ID', j.data.user.id);",
                  "  if (j.data.user && j.data.user.email) pm.collectionVariables.set('EMAIL', j.data.user.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{EMAIL}}\",\n  \"password\": \"Guest12345!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login (SUPER_ADMIN seed)",
